# 复制为 .env.development 或 .env.production 后填写

# 代理鉴权（必填，非 DEV 模式）
PROXY_API_KEY=

# Admin Key 管理（可选，用于 /admin/keys 鉴权）
ADMIN_KEY=

# 数据库（可选，用于 keys 表）
DATABASE_URL=
DATABASE_PUBLIC_URL=

# Redis（可选，用于 ENABLE_GLOBAL_ROUND_ROBIN 时的 Key 轮询，支持 redis:// URL）
REDIS_URL=
REDIS_PUBLIC_URL=

# Provider API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# ... 其他按需配置

# 配置
DEV=false
DEFAULT_MODEL=
ENABLE_GLOBAL_ROUND_ROBIN=false
